class Solution {
    public boolean isSubsequence(String s, String t) {

          char st1[] = s.toCharArray();
        char st2[] = t.toCharArray();

        int j = 0;

        for (int i = 0; i < st2.length; i++) {
            if (j < st1.length && st2[i] == st1[j]) {
                j++;
            }
        }

        return j == st1.length;
    }
}
